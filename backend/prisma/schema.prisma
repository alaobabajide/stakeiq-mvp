generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ───────────────────────────────────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  fullName    String
  phone       String   @unique
  dateOfBirth DateTime
  state       String
  pinHash     String
  kycStatus   KycStatus @default(PENDING)
  role        UserRole  @default(BETTOR)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kyc              Kyc?
  wallet           Wallet?
  bsr              Bsr?
  betslips         Betslip[]
  transactions     Transaction[]
  withdrawals      Withdrawal[]
  spendingLimit    SpendingLimit?
  tipsterProfile   Tipster?
  tipSubscriptions TipsterSubscription[]
  selfExclusion    SelfExclusion?

  @@map("users")
}

enum KycStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum UserRole {
  BETTOR
  TIPSTER
  ADMIN
}

// ─── KYC ─────────────────────────────────────────────────────────────────────
model Kyc {
  id          String    @id @default(uuid())
  userId      String    @unique
  bvn         String?
  idType      IdType?
  idNumber    String?
  idFrontUrl  String?
  idBackUrl   String?
  selfieUrl   String?
  address     String?
  city        String?
  kycState    String?
  status      KycStatus @default(PENDING)
  reviewNote  String?
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc")
}

enum IdType {
  NIN
  PVC
  PASSPORT
  DRIVERS_LICENSE
}

// ─── WALLET ───────────────────────────────────────────────────────────────────
model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  balance          Decimal  @default(0) @db.Decimal(12, 2)
  lockedBalance    Decimal  @default(0) @db.Decimal(12, 2)
  totalDeposited   Decimal  @default(0) @db.Decimal(12, 2)
  totalWithdrawn   Decimal  @default(0) @db.Decimal(12, 2)
  totalWon         Decimal  @default(0) @db.Decimal(12, 2)
  totalStaked      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

// ─── TRANSACTIONS ─────────────────────────────────────────────────────────────
model Transaction {
  id          String            @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal           @db.Decimal(12, 2)
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)
  status      TransactionStatus @default(PENDING)
  reference   String            @unique @default(uuid())
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  STAKE
  WIN
  REFUND
  BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

// ─── MATCHES ─────────────────────────────────────────────────────────────────
model Match {
  id          String      @id @default(uuid())
  league      String
  leagueCode  String?
  homeTeam    String
  awayTeam    String
  homeScore   Int?
  awayScore   Int?
  status      MatchStatus @default(UPCOMING)
  startTime   DateTime
  endTime     DateTime?
  minute      Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  odds        Odd[]
  betItems    BetslipItem[]

  @@index([status])
  @@index([startTime])
  @@map("matches")
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
  POSTPONED
}

// ─── ODDS ─────────────────────────────────────────────────────────────────────
model Odd {
  id        String     @id @default(uuid())
  matchId   String
  outcome   OddOutcome
  label     String
  value     Decimal    @db.Decimal(6, 2)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  match    Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  betItems BetslipItem[]

  @@unique([matchId, outcome])
  @@index([matchId])
  @@map("odds")
}

enum OddOutcome {
  HOME_WIN
  DRAW
  AWAY_WIN
  OVER_25
  UNDER_25
  BTTS_YES
  BTTS_NO
}

// ─── BETSLIP ─────────────────────────────────────────────────────────────────
model Betslip {
  id           String        @id @default(uuid())
  userId       String
  status       BetslipStatus @default(OPEN)
  totalOdds    Decimal       @db.Decimal(10, 4)
  stake        Decimal       @db.Decimal(12, 2)
  potentialWin Decimal       @db.Decimal(12, 2)
  actualWin    Decimal?      @db.Decimal(12, 2)
  settledAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items BetslipItem[]

  @@index([userId])
  @@index([status])
  @@map("betslips")
}

enum BetslipStatus {
  OPEN
  WON
  LOST
  CANCELLED
  VOID
}

model BetslipItem {
  id        String  @id @default(uuid())
  betslipId String
  matchId   String
  oddId     String
  outcome   OddOutcome
  oddValue  Decimal @db.Decimal(6, 2)
  result    BetItemResult?
  createdAt DateTime @default(now())

  betslip Betslip @relation(fields: [betslipId], references: [id], onDelete: Cascade)
  match   Match   @relation(fields: [matchId], references: [id])
  odd     Odd     @relation(fields: [oddId], references: [id])

  @@index([betslipId])
  @@map("betslip_items")
}

enum BetItemResult {
  WON
  LOST
  VOID
}

// ─── BSR (Bettor Skill Rating) ────────────────────────────────────────────────
model Bsr {
  id          String   @id @default(uuid())
  userId      String   @unique
  score       Int      @default(0)
  level       BsrLevel @default(BRONZE)
  winRate     Decimal  @default(0) @db.Decimal(5, 2)
  totalBets   Int      @default(0)
  wonBets     Int      @default(0)
  lostBets    Int      @default(0)
  monthlyBets Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bsr")
}

enum BsrLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ─── TIPSTERS ─────────────────────────────────────────────────────────────────
model Tipster {
  id                String   @id @default(uuid())
  userId            String   @unique
  displayName       String
  bio               String?
  subscriptionPrice Decimal? @db.Decimal(10, 2)
  isFree            Boolean  @default(false)
  isVerified        Boolean  @default(false)
  subscriberCount   Int      @default(0)
  totalTips         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tips          Tip[]
  subscriptions TipsterSubscription[]

  @@map("tipsters")
}

model Tip {
  id          String    @id @default(uuid())
  tipsterId   String
  matchId     String?
  prediction  String
  reasoning   String?
  odds        Decimal?  @db.Decimal(6, 2)
  result      TipResult?
  isFree      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tipster Tipster @relation(fields: [tipsterId], references: [id], onDelete: Cascade)

  @@index([tipsterId])
  @@map("tips")
}

enum TipResult {
  WIN
  LOSS
  VOID
}

model TipsterSubscription {
  id          String   @id @default(uuid())
  userId      String
  tipsterId   String
  startDate   DateTime @default(now())
  endDate     DateTime
  isActive    Boolean  @default(true)
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipster Tipster @relation(fields: [tipsterId], references: [id], onDelete: Cascade)

  @@unique([userId, tipsterId])
  @@map("tipster_subscriptions")
}

// ─── WITHDRAWALS ──────────────────────────────────────────────────────────────
model Withdrawal {
  id            String           @id @default(uuid())
  userId        String
  amount        Decimal          @db.Decimal(12, 2)
  method        PaymentMethod
  accountNumber String
  accountName   String?
  bankName      String?
  status        WithdrawalStatus @default(PENDING)
  reference     String           @unique @default(uuid())
  processedAt   DateTime?
  failureReason String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

enum PaymentMethod {
  OPAY
  PALMPAY
  BANK_TRANSFER
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

// ─── SPENDING LIMITS ──────────────────────────────────────────────────────────
model SpendingLimit {
  id           String   @id @default(uuid())
  userId       String   @unique
  monthlyLimit Decimal  @db.Decimal(12, 2)
  dailyLimit   Decimal? @db.Decimal(12, 2)
  weeklyLimit  Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("spending_limits")
}

// ─── SELF EXCLUSION ───────────────────────────────────────────────────────────
model SelfExclusion {
  id          String   @id @default(uuid())
  userId      String   @unique
  startDate   DateTime @default(now())
  endDate     DateTime
  durationDays Int
  reason      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("self_exclusions")
}
